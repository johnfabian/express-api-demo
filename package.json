{
  "name": "express-api-demo",
  "private": true,
  "workspaces": [
    "server",
    "client/express-client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c blue,magenta \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --workspace=express-server",
    "dev:client": "npm run dev --workspace=express-client",
    "start": "npm run start --workspace=express-server",
    "database": "npm run database --workspace=express-server",
    "db:pull": "npm run db:pull --workspace=express-server",
    "db:reseed-products": "npm run db:reseed-products --workspace=express-server",
    "stop-servers": "bash scripts/stop-servers.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
